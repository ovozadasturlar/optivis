{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/optivis-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "ConnectionStrings": {
    "MariaDb": "Server=localhost;Port=3306;Database=asteriskcdrdb;User=root;Password=optivis123;"
  },
  "CdrPolling": {
    "IntervalSeconds": 10
  },
  "OperatorMapping": {
    "PrimaryExtensions": ["01", "02", "03", "04", "05", "06", "07", "08", "09", "10"],
    "ForwardMapping": {
      "5809": "06",
      "5999": "05",
      "6000": "04",
      "3030": "03",
      "5030": "02",
      "5040": "04",
      "6010": "06",
      "3020": "02",
      "7540": "07"
    }
  },
  "AllowedHosts": "*"
}   
