<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OptiVis.UI.Shared.ViewModels"
             xmlns:conv="using:OptiVis.UI.Shared.Converters"
             xmlns:ext="using:OptiVis.UI.Shared.Extensions"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             x:Class="OptiVis.UI.Shared.Views.SearchView"
             x:DataType="vm:SearchViewModel">

    <UserControl.Resources>
        <conv:StatusColorConverter x:Key="StatusColor"/>
        <conv:StatusIconConverter x:Key="StatusIcon"/>
        <conv:DirectionIconConverter x:Key="DirectionIcon"/>
        <conv:DirectionColorConverter x:Key="DirectionColor"/>
        <conv:DurationFormatConverter x:Key="DurationFormat"/>
    </UserControl.Resources>

    <Grid>
        <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="24">
            <TextBlock Grid.Row="0" Text="{ext:Localize Numbers}" Classes="title" Margin="0,0,0,16"/>
            
            <Border Grid.Row="1" Classes="card" Margin="0,0,0,12" Padding="10">
                <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button Classes="pill-button" Click="OnSetToday" Content="{ext:Localize Today}"/>
                        <Button Classes="pill-button" Click="OnSetYesterday" Content="{ext:Localize Yesterday}"/>
                        <Button Classes="pill-button" Click="OnSetWeek" Content="{ext:Localize Week}"/>
                        <Button Classes="pill-button" Click="OnSetMonth" Content="{ext:Localize Month}"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{ext:Localize From}" VerticalAlignment="Center"/>
                        <DatePicker SelectedDate="{Binding FromDate}" Width="140"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{ext:Localize To}" VerticalAlignment="Center"/>
                        <DatePicker SelectedDate="{Binding ToDate}" Width="140"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="3" Classes="card">
                <Grid RowDefinitions="Auto, *">
                    <Grid ColumnDefinitions="Auto * Auto" Margin="0,0,0,12">
                        <Border Background="{DynamicResource HoverBrush}" CornerRadius="10" Padding="10 5 5 5">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <i:Icon Value="mdi-magnify" FontSize="18" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding SearchText}" 
                                         Watermark="{ext:Localize SearchByNumber}" 
                                         Width="300" 
                                         BorderThickness="0"
                                         Background="Transparent"/>
                            </StackPanel>
                        </Border>
                        <Button Grid.Column="2" HorizontalContentAlignment="Right" Classes="primary-button" Click="OnExportExcel">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <i:Icon Value="mdi-download" FontSize="16"/>
                                <TextBlock Text="{ext:Localize ExcelExport}"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                    <DataGrid Grid.Row="1"
                          ItemsSource="{Binding FilteredRecords}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="{ext:Localize PhoneNumber}" Width="2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="4">
                                        <Border Width="32" Height="32" CornerRadius="16" Background="#3B82F6">
                                            <i:Icon Value="mdi-phone" FontSize="16" Foreground="White"/>
                                        </Border>
                                        <TextBlock Text="{Binding PhoneNumber}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="{ext:Localize TotalCalls}" Width="*" Binding="{Binding TotalCalls}"/>
                        <DataGridTextColumn Header="{ext:Localize Success}" Width="*" Binding="{Binding SuccessfulCalls}"/>
                        <DataGridTextColumn Header="{ext:Localize Cancelled}" Width="*" Binding="{Binding CancelledCalls}"/>
                        <DataGridTextColumn Header="{ext:Localize NoAnswer}" Width="*" Binding="{Binding NoAnswerCalls}"/>
                        <DataGridTextColumn Header="{ext:Localize Busy}" Width="*" Binding="{Binding BusyCalls}"/>
                        <DataGridTextColumn Header="{ext:Localize LastCall}" Width="1.5*" Binding="{Binding LastCallDate, StringFormat={}{0:dd.MM.yyyy HH:mm}, Mode=OneWay}"/>
                        <DataGridTemplateColumn Header="{ext:Localize Actions}" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Classes="primary-button" FontSize="11" Padding="8,4" HorizontalAlignment="Center" Click="OnViewDetailsClick">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <i:Icon Value="mdi-eye" FontSize="14"/>
                                            <TextBlock Text="{ext:Localize View}"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
                    </Grid>
            </Border>
        </Grid>

        <Grid Background="#80000000" IsVisible="{Binding IsDetailPopupOpen}">
            <Border Classes="card" HorizontalAlignment="Center" VerticalAlignment="Center" 
                    Width="900" MinHeight="400" MaxHeight="700" BoxShadow="0 8 32 0 #60000000">
                <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="24">
                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="{ext:Localize CallDetails}" Classes="title"/>
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                <i:Icon Value="mdi-phone" FontSize="16" Foreground="{DynamicResource AccentBrush}"/>
                                <TextBlock Text="{Binding SelectedPhoneNumber.PhoneNumber, Mode=OneWay}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}"/>
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1" Classes="icon-button" Click="OnClosePopupClick">
                            <i:Icon Value="mdi-close" FontSize="20"/>
                        </Button>
                    </Grid>
                    
                    <Border Grid.Row="1" Background="{DynamicResource HoverBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal" Spacing="32">
                            <StackPanel>
                                <TextBlock Text="{ext:Localize TotalCalls}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding SelectedPhoneNumber.TotalCalls, Mode=OneWay}" FontSize="18" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="{ext:Localize Success}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding SelectedPhoneNumber.SuccessfulCalls, Mode=OneWay}" FontSize="18" FontWeight="Bold" Foreground="#10B981"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="{ext:Localize NoAnswer}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding SelectedPhoneNumber.NoAnswerCalls, Mode=OneWay}" FontSize="18" FontWeight="Bold" Foreground="#F59E0B"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="{ext:Localize Cancelled}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding SelectedPhoneNumber.CancelledCalls, Mode=OneWay}" FontSize="18" FontWeight="Bold" Foreground="#6B7280"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="{ext:Localize Busy}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding SelectedPhoneNumber.BusyCalls, Mode=OneWay}" FontSize="18" FontWeight="Bold" Foreground="#EF4444"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Vaqt oralig'i va kiruvchi/chiquvchi bo'yicha filtr -->
                    <Border Grid.Row="2" Background="{DynamicResource CardBackgroundBrush}" 
                            BorderBrush="{DynamicResource BorderBrush}" 
                            BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                            <TextBlock Grid.Column="0" Text="{ext:Localize CallsInSelectedPeriod}" 
                                       FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <i:Icon Value="mdi-calendar-range" FontSize="14" 
                                            Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding FromDate, StringFormat={}{0:dd.MM.yyyy}, Mode=OneWay}" 
                                               FontSize="11" VerticalAlignment="Center"/>
                                    <TextBlock Text=" — " FontSize="11" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding ToDate, StringFormat={}{0:dd.MM.yyyy}, Mode=OneWay}" 
                                               FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <ScrollViewer Grid.Row="3" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SelectedNumberDetails}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource CardBackgroundBrush}" 
                                            BorderBrush="{DynamicResource BorderBrush}" 
                                            BorderThickness="1" 
                                            CornerRadius="8" 
                                            Padding="12" 
                                            Margin="0,0,0,8">
                                        <Grid ColumnDefinitions="Auto,*,80,80,100">
                                            <Border Width="40" Height="40" CornerRadius="20" 
                                                    Background="{Binding Direction, Mode=OneWay, Converter={StaticResource DirectionColor}}" 
                                                    Margin="0,0,12,0">
                                                <i:Icon Value="{Binding Direction, Mode=OneWay, Converter={StaticResource DirectionIcon}}" 
                                                        FontSize="20" Foreground="White"/>
                                            </Border>
                                            
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{Binding OperatorName, Mode=OneWay}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding OperatorExtension, Mode=OneWay, StringFormat=(Ext: {0})}" 
                                                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" 
                                                               VerticalAlignment="Center"
                                                               IsVisible="{Binding OperatorExtension, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding CallDate, Mode=OneWay, StringFormat={}{0:dd.MM.yyyy HH:mm:ss}}" 
                                                           FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            </StackPanel>
                                            
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" 
                                                        VerticalAlignment="Center" HorizontalAlignment="Center"
                                                        ToolTip.Tip="Davomiylik">
                                                <i:Icon Value="mdi-clock-outline" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Text="{Binding DurationFormatted, Mode=OneWay}" FontSize="12" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            
                                            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4" 
                                                        VerticalAlignment="Center" HorizontalAlignment="Center"
                                                        ToolTip.Tip="Suhbat vaqti">
                                                <i:Icon Value="mdi-phone-in-talk" FontSize="14" Foreground="#10B981"/>
                                                <TextBlock Text="{Binding BillSecFormatted, Mode=OneWay}" FontSize="12" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                            </StackPanel>
                                            
                                            <Border Grid.Column="4" CornerRadius="12" Padding="10,4" 
                                                    Background="{Binding Disposition, Mode=OneWay, Converter={StaticResource StatusColor}}"
                                                    VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <i:Icon Value="{Binding Disposition, Mode=OneWay, Converter={StaticResource StatusIcon}}" 
                                                            FontSize="14" Foreground="White"/>
                                                    <TextBlock Text="{Binding Disposition, Mode=OneWay}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
