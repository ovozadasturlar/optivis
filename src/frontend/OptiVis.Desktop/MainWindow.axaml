<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:OptiVis.UI.Shared.ViewModels"
        xmlns:views="using:OptiVis.UI.Shared.Views"
        mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="750"
        x:Class="OptiVis.Desktop.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="OptiVis - Precision Lens"
        Width="1400" Height="750"
        MinWidth="1200" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Icon="avares://OptiVis.Desktop/icon.png">

    <views:ShellView DataContext="{Binding}"/>
</Window>
